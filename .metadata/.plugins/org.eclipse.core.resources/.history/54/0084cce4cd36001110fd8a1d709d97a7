package com.kh.select.run;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.ResultSet;
import java.sql.SQLException;
import java.sql.Statement;

public class SelectSpeciesRun {

	public static void main(String[] args) {

		ResultSet rset = null;
		String sql = """
                        SELECT
                               SPECIES_ID,
                               SPECIES_NAME,
                               SPECIES_CLASS
                          FROM 
                               KEEPER
                  
                     """;		
		
		try {
			Class.forName("oracle.jdbc.driver.OracleDriver");
		} catch (ClassNotFoundException e) {
			e.printStackTrace();
		}
		
		try(Connection conn = DriverManager.getConnection("jdbc:oracle:thin:@127.0.0.1:1521:XE", "C##SP", "SP");
			Statement stmt = conn.createStatement()){
			rset = stmt.executeQuery(sql);
			while(rset.next()) {
				System.out.println("종 번호 : " + rset.getString("SPECIES_ID")
				                 + ", 종 이름 : " + rset.getString("SPECIES_NAME")
				                 + ", 종 분류 : " + rset.getString("SPECIES_CLASS"));
			}
		} catch(SQLException e) {
			e.printStackTrace();
		}
		
	}

}
