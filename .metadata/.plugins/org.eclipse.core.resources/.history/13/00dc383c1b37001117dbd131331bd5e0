package com.kh.zone.model.dao;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.ResultSet;
import java.sql.SQLException;
import java.sql.Statement;
import java.util.ArrayList;
import java.util.List;

import com.kh.zone.model.dto.ZoneDto;

public class ZoneDao {

	static {
		try {
			Class.forName("oracle.jdbc.driver.OracleDriver");
		} catch (ClassNotFoundException e) {
			e.printStackTrace();
		}
	}
	
	public int save(ZoneDto zoneDto) {
		
		int result = 0;
		try(Connection conn = DriverManager.getConnection("jdbc:oracle:thin:@127.0.0.1:1521:XE", "C##SP", "SP");
			Statement stmt = conn.createStatement()){
			
			String sql = "INSERT "
					     + "INTO "
					          + "ZONE "
					   + "VALUES "
					          + "("
					          + "SEQ_ZONE.NEXTVAL"
					        + ", '" + zoneDto.getZoneName() + "'"
					        + ", '" + zoneDto.getZoneType() + "'"
					          + ")";
			result = stmt.executeUpdate(sql);
			
		} catch (SQLException e) {
			e.printStackTrace();
		}
		return result;
	}

	public List<ZoneDto> findAll() {
		
		List<ZoneDto> list = new ArrayList();
		
		String sql = """
				        SELECT
				               ZONE_ID,
				               ZONE_NAME,
				               ZONE_TYPE
				          FROM
				               ZONE
				         ORDER
				            BY
				               ZONE_ID DESC           
				     """;
		try(Connection conn = DriverManager.getConnection("jdbc:oracle:thin:@127.0.0.1:1521:XE", "C##SP", "SP");
			Statement stmt = conn.createStatement();
			ResultSet rset = stmt.executeQuery(sql);){
			while(rset.next()) {
				list.add(new ZoneDto(rset.getString("ZONE_ID"), rset.getString("ZONE_NAME"), rset.getString("ZONE_TYPE")));
			}
		} catch (SQLException e) {
			e.printStackTrace();
		}
		return list;
	}

	public int update(ZoneDto zoneDto) {
		int result = 0;
		String sql = "UPDATE "
				          + "ZONE "
				      + "SET "
				          + "ZONE_NAME" + "'" + zoneDto.getZoneName() + "', "
				          + "ZONE_TYPE" + "'" + zoneDto.getZoneType() + "'"
				    + "WHERE "
				          + "ZONE_ID" + " = '" + zoneDto.getZoneId() + "'";
		try(Connection conn = DriverManager.getConnection("jdbc:oracle:thin:@127.0.0.1:1521:XE", "C##SP", "SP");
			Statement stmt = conn.createStatement()){
			result = stmt.executeUpdate(sql);
		} catch (SQLException e) {
			e.printStackTrace();
		}
		return result;
	}
}
